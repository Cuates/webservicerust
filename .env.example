# =============================================================================
#  .env.example — Copy this file to .env and fill in real values.
#  NEVER commit .env to source control.
#  Generate API keys:  scripts/generate-api-key.sh  (or .ps1)
#  Revoke API keys:    scripts/revoke-api-key.sh    (or .ps1)
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_PORT=4815

# Bind host for the TCP listener.
# 127.0.0.1 → localhost only (Postman / VSCode REST can reach it; LAN cannot).
# 0.0.0.0   → all interfaces (use if you need LAN or Docker-external access).
BIND_HOST=127.0.0.1

# Logging level: trace | debug | info | warn | error
RUST_LOG=info

# Timezone for the container (passed as Docker build arg AND runtime env)
TIMEZONE_LOCATION=America/Los_Angeles

# ── Database ──────────────────────────────────────────────────────────────────
# Active database engine. Switching requires only changing this value + restart.
# Allowed values: postgres | mariadb | mssql
DATABASE_TARGET=postgres

# PostgreSQL connection URL
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
POSTGRES_URL=postgresql://username:password@postgres:5432/database_name

# MariaDB connection URL
# Format: mysql://<user>:<password>@<host>:<port>/<database>?charset=utf8mb4
MARIADB_URL=mysql://username:password@mariadb:3306/database_name?charset=utf8mb4

# MSSQL connection (tiberius — no ODBC required)
MSSQL_HOST=mssql
MSSQL_PORT=1433
MSSQL_DATABASE=database_name
MSSQL_USERNAME=username
MSSQL_PASSWORD=password

# ── Security — API Keys ───────────────────────────────────────────────────────
# Comma-separated list of valid API keys.
# Each consumer (Angular via NPM, Postman, VSCode REST, etc.) should have its own key.
# Example: API_KEYS=npmprod-abc123...,postman-def456...,vscode-ghi789...
#
# Nginx Proxy Manager: add to Proxy Host → Advanced:
#   proxy_set_header X-API-Key "your-npm-key-here";
#
# All API requests must include header: X-API-Key: <key>
API_KEYS=

# ── Rate Limiting (tower-governor) ────────────────────────────────────────────
# Requests per second per client IP (token bucket replenish rate)
RATE_LIMIT_RPS=10

# Maximum burst size above the steady-state rate
RATE_LIMIT_BURST=30

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slashes)
ALLOWED_ORIGINS=http://localhost:4200,https://subdomain.domain.com
